{
  "name": "issue-youtube-tool",
  "version": "3.6.2",
  "description": "유튜브도사 영상 제작 솔루션 — 체인저스캠퍼스",
  "main": "main.js",
  "private": true,
  "license": "UNLICENSED",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "dev:vite": "vite --config vite.config.js",
    "dev:electron": "cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .",
    "build": "vite build --config vite.config.js",
    "lint": "node scripts/lint.js",
    "test:smoke": "node scripts/smoke-test.js",
    "test:unit": "node scripts/unit-test.js",
    "test": "node scripts/smoke-test.js && node scripts/unit-test.js",
    "test:structure": "node scripts/structure-test.js",
    "test:all": "node scripts/smoke-test.js && node scripts/unit-test.js && node scripts/structure-test.js",
    "check-version": "node scripts/check-version.js",
    "verify": "npm run check-version && npm run lint && npm run test && npm run build",
    "start": "electron .",
    "build:win": "npm run verify && electron-builder --win --publish never",
    "build:mac": "npm run verify && electron-builder --mac dmg zip --arm64 --publish never",
    "build:mac:arm64": "npm run verify && electron-builder --mac dmg zip --arm64 --publish never",
    "build:mac:x64": "npm run verify && electron-builder --mac dmg zip --x64 --publish never",
    "build:all": "npm run verify && electron-builder --win --mac --publish never",
    "deploy": "npm run verify && electron-builder --win --publish always",
    "deploy:mac": "npm run verify && electron-builder --mac dmg zip --universal --publish always",
    "deploy:all": "npm run verify && electron-builder --win --mac --publish always",
    "remotion:install": "cd remotion && npm install",
    "remotion:studio": "cd remotion && npx remotion studio"
  },
  "build": {
    "appId": "com.changerscampus.issue-youtube-tool",
    "productName": "유튜브도사 영상 제작 솔루션",
    "artifactName": "youtube-dosa-${version}-${os}-${arch}.${ext}",
    "asar": true,
    "asarUnpack": [
      "node_modules/ffmpeg-static/**",
      "remotion/**"
    ],
    "files": [
      "main.js",
      "main/**/*",
      "preload.js",
      "shared-config.json",
      "dist/**/*",
      "api-key-guide/**/*",
      "build/**/*",
      "remotion/**/*",
      "!dist/**/*.map"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "hoon7624g-web",
        "repo": "issue-youtube-tool",
        "releaseType": "release"
      }
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "shortcutName": "유튜브도사 영상 제작 솔루션"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.productivity",
      "icon": "build/icon.icns"
    },
    "dmg": {
      "icon": "build/icon.icns"
    }
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "electron": "~33.0.0",
    "electron-builder": "^25.0.0",
    "vite": "^8.0.2"
  },
  "dependencies": {
    "@remotion/bundler": "4.0.487",
    "@remotion/renderer": "4.0.487",
    "electron-log": "^5.2.0",
    "electron-updater": "^6.3.0",
    "ffmpeg-static": "^5.2.0",
    "jszip": "^3.10.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "remotion": "4.0.487"
  }
}
